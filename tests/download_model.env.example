# 下载源: hf 或 modelscope
MODEL_HUB=hf

# Hugging Face / ModelScope 模型名
MODEL_ID=Qwen/Qwen2.5-0.5B-Instruct

# 本地落盘目录
# 按当前模型名落盘，后续如果要接入 compose，再按实际部署路径调整
MODEL_OUTPUT_DIR=/home/dev/model/Qwen/Qwen2.5-0.5B-Instruct

# 仓库类型，通常保持 model 即可
MODEL_REPO_TYPE=model

# Hugging Face 镜像地址
HF_ENDPOINT=https://hf-mirror.com

# 如果使用 hf 下载，需要填自己的 token
HF_TOKEN=
